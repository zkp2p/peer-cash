{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "exactOptionalPropertyTypes": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "paths": {
      "@zkp2p/cash": ["./src/index.ts"],
      "@zkp2p/cash/react": ["./src/react/index.ts"],
      "@zkp2p/cash/tools": ["./src/tools/index.ts"]
    }
  },
  "include": ["src", "test", "examples", "tsup.config.ts", "vitest.config.ts"]
}
